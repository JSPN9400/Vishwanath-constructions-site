# .env.local — copy this to .env.local and fill in your values

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/roadmaper"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-random-secret-key-here"  # generate: openssl rand -base64 32

# OAuth providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# Anthropic AI (required for AI roadmap generation)
ANTHROPIC_API_KEY="sk-ant-..."

# Web Push Notifications (VAPID keys)
# Generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="admin@roadmaper.com"
